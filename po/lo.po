#: data/metainfo/catfish.appdata.xml.in:7
msgid "Catfish"
msgstr "Catfish"

#: data/ui/CatfishWindow.ui:703
msgid "Update"
msgstr "ອັບເດດ"

#: data/ui/CatfishWindow.ui:744
msgid "The search database is more than 7 days old.  Update now?"
msgstr "ຖານຂໍ້ມູນການຄົ້ນຫາມີອາຍຸເກີນ 7 ວັນແລ້ວ. ອັບເດດດຽວນີ້ເລີຍບໍ່?"

#: data/ui/CatfishWindow.ui:802
msgid "File Type"
msgstr "ປະເພດໄຟລ໌"

#: data/ui/CatfishWindow.ui:941 catfish/CatfishWindow.py:1721
msgid "Modified"
msgstr "ຖືກແກ້ໄຂ"

#: data/ui/CatfishWindow.ui:1132 catfish/CatfishWindow.py:2376
msgid "Results will be displayed as soon as they are found."
msgstr "ຜົນການຄົ້ນຫາຈະຖືກສະແດງທັນທີທີ່ພົບ."

#: data/ui/CatfishWindow.ui:1269
msgid "Unlock"
msgstr "ປົດລັອກ"

#: data/ui/CatfishWindow.ui:1321
msgid "<b>Database:</b>"
msgstr "<b>ຖານຂໍ້ມູນ:</b>"

#: data/ui/CatfishWindow.ui:1334
msgid "<b>Updated:</b>"
msgstr "<b>ອັບເດດແລ້ວ:</b>"

#: data/ui/CatfishWindow.ui:1347
msgid "<big><b>Update Search Database</b></big>"
msgstr "<big><b>ອັບເດດຖານຂໍ້ມູນການຄົ້ນຫາ</b></big>"

#: data/ui/CatfishWindow.ui:1361
msgid ""
"For faster search results, the search database needs to be refreshed.\n"
"This action requires administrative rights."
msgstr ""
"ເພື່ອຜົນການຄົ້ນຫາທີ່ໄວຂຶ້ນ, ຖານຂໍ້ມູນການຄົ້ນຫາຈຳເປັນຕ້ອງໄດ້ຮັບການຟື້ນຟູໃໝ່.\n"
"ການດຳເນີນການນີ້ຕ້ອງການສິດຜູ້ດູແລລະບົບ."

#: data/ui/CatfishWindow.ui:1493
msgid "Update Search Database"
msgstr "ອັບເດດຖານຂໍ້ມູນການຄົ້ນຫາ"

#: data/ui/CatfishWindow.ui:1517
msgid "Search for files"
msgstr "ຄົ້ນຫາໄຟລ໌"

#: data/ui/CatfishWindow.ui:1563
msgid "Compact List"
msgstr "ລາຍການແບບກະທັດຮັດ"

#: data/ui/CatfishWindow.ui:1582
msgid "Thumbnails"
msgstr "ຮູບຕົວຢ່າງ"

#: data/ui/CatfishWindow.ui:1633
msgid "Show _sidebar"
msgstr "ສະແດງ_ແຖບຂ້າງ"

#: data/ui/CatfishWindow.ui:1672
msgid "Show _hidden files"
msgstr "ສະແດງໄຟລ໌ທີ່_ຊ່ອນໄວ້"

#: data/ui/CatfishWindow.ui:1687
msgid "Search file _contents"
msgstr "ຄົ້ນຫາ_ເນື້ອໃນໄຟລ໌"

#: data/ui/CatfishWindow.ui:1704
msgid "_Match results exactly"
msgstr "_ຜົນການຄົ້ນຫາຕ້ອງກົງກັນທັງໝົດ"

#: data/ui/CatfishWindow.ui:1757
msgid "_Refresh search index..."
msgstr "_ຟື້ນຟູດັດຊະນີການຄົ້ນຫາ..."

#: data/ui/CatfishWindow.ui:1812
msgid "_Preferences"
msgstr "_ການຕັ້ງຄ່າ"

#: data/ui/CatfishWindow.ui:1853
msgid "_About"
msgstr "_ກ່ຽວກັບ"

#: catfish/__init__.py:39
msgid "Usage: %prog [options] path query"
msgstr "ວິທີໃຊ້: %prog [ຕົວເລືອກ] ເສັ້ນທາງ ຄຳຄົ້ນຫາ"

#: catfish/__init__.py:44
msgid "Show debug messages (-vv will also debug catfish_lib)"
msgstr "ສະແດງຂໍ້ຄວາມດີບັກ (-vv ຈະດີບັກ catfish_lib ນຳ)"

#: catfish/__init__.py:47
msgid "Use large icons"
msgstr "ໃຊ້ໄອຄອນຂະໜາດໃຫຍ່"

#: catfish/__init__.py:49
msgid "Use thumbnails"
msgstr "ໃຊ້ຮູບຕົວຢ່າງ"

#: catfish/__init__.py:51
msgid "Display time in ISO format"
msgstr "ສະແດງເວລາໃນຮູບແບບ ISO"

#. Translators: Do not translate PATH, it is a variable.
#: catfish/__init__.py:53
msgid "Set the default search path"
msgstr "ຕັ້ງຄ່າເສັ້ນທາງການຄົ້ນຫາເລີ່ມຕົ້ນ"

#: catfish/__init__.py:55
msgid "Perform exact match"
msgstr "ດຳເນີນການຄົ້ນຫາແບບກົງກັນທຸກຕົວອັກສອນ"

#: catfish/__init__.py:57
msgid "Include hidden files"
msgstr "ລວມເອົາໄຟລ໌ທີ່ຊ່ອນໄວ້"

#: catfish/__init__.py:59
msgid "Perform fulltext search"
msgstr "ດຳເນີນການຄົ້ນຫາແບບເຕັມຂໍ້ຄວາມ"

#: catfish/__init__.py:61
msgid ""
"If path and query are provided, start searching when the application is "
"displayed."
msgstr ""
"ຖ້າມີການລະບຸເສັ້ນທາງ ແລະ ຄຳຄົ້ນຫາ, "
"ຈະເລີ່ມການຄົ້ນຫາທັນທີເມື່ອແອັບພລິເຄຊັນເປີດຂຶ້ນ."

#: catfish/__init__.py:63
msgid "set a default column to sort by (name|size|path|date|type),(asc|desc)"
msgstr ""
"ຕັ້ງຄ່າຄໍລຳເລີ່ມຕົ້ນເພື່ອຈັດລຽງຕາມ "
"(ຊື່|ຂະໜາດ|ເສັ້ນທາງ|ວັນທີ|ປະເພດ),(ນ້ອຍຫາໃຫຍ່|ໃຫຍ່ຫານ້ອຍ)"

#: catfish/__init__.py:66
msgid "Close after selecting a file"
msgstr "ປິດຫຼັງຈາກເລືອກໄຟລ໌"

#: catfish/__init__.py:68
msgid "Do not close after selecting a file"
msgstr "ບໍ່ຕ້ອງປິດຫຼັງຈາກເລືອກໄຟລ໌"

#. Translators: this text is displayed next to
#. a filename that is not utf-8 encoded.
#: catfish/CatfishWindow.py:110
#, python-format
msgid "%s (invalid encoding)"
msgstr "%s (ການຖອດລະຫັດບໍ່ຖືກຕ້ອງ)"

#: catfish/CatfishWindow.py:152
msgid "translator-credits"
msgstr "ລາຍຊື່ຜູ້ແປ"

#: catfish/CatfishWindow.py:303
msgid "Unknown"
msgstr "ບໍ່ຮູ້ຈັກ"

#: catfish/CatfishWindow.py:307
msgid "Never"
msgstr "ບໍ່ເຄີຍ"

#: catfish/CatfishWindow.py:419
#, python-format
msgid ""
"Enter your query above to find your files\n"
"or click the %s icon for more options."
msgstr ""
"ປ້ອນຄຳຄົ້ນຫາຂອງເຈົ້າຢູ່ຂ້າງເທິງເພື່ອຊອກຫາໄຟລ໌\n"
"ຫຼື ຄລິກໄອຄອນ %s ສຳລັບຕົວເລືອກເພີ່ມເຕີມ."

#: catfish/CatfishWindow.py:824
msgid "An error occurred while updating the database."
msgstr "ເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ອັບເດດຖານຂໍ້ມູນ."

#: catfish/CatfishWindow.py:826
msgid "Authentication failed."
msgstr "ການຢືນຢັນຕົວຕົນລົ້ມເຫຼວ."

#: catfish/CatfishWindow.py:832
msgid "Authentication cancelled."
msgstr "ການຢືນຢັນຕົວຕົນຖືກຍົກເລີກ."

#: catfish/CatfishWindow.py:838
msgid "Search database updated successfully."
msgstr "ອັບເດດຖານຂໍ້ມູນການຄົ້ນຫາສຳເລັດແລ້ວ."

#. Update the Cancel button to Close, make it default
#: catfish/CatfishWindow.py:899
msgid "Close"
msgstr "ປິດ"

#. Set the dialog status to running.
#: catfish/CatfishWindow.py:913
msgid "Updating..."
msgstr "ກຳລັງອັບເດດ..."

#: catfish/CatfishWindow.py:948
msgid "Stop Search"
msgstr "ຢຸດການຄົ້ນຫາ"

#: catfish/CatfishWindow.py:949
msgid ""
"Search is in progress...\n"
"Press the cancel button or the Escape key to stop."
